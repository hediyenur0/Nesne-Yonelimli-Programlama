using System;

//İki sayının ortalamasını return ile döndüren metodu yazınız.

class Program
{
    static double Ortalama(int a, int b)
    {
        return (a + b) / 2.0;
    }

    static void Main(string[] args)
    {
        double sonuc = Ortalama(10, 20);
        Console.WriteLine("Ortalama: " + sonuc);
    }
}
